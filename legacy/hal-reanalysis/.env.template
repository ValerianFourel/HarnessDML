# Copy to .env (gitignored) and fill in. Nothing here is read by committed code
# directly; notebooks/scripts read the environment.

# Hugging Face token. The dataset agent-evals/hal_traces is public and ungated
# (verified 2026-07-23), so this is optional — set it anyway on the cluster to
# avoid anonymous rate limits.
HF_TOKEN=

# Scratch directory for raw + decrypted traces + parquet cache (HPC side).
# The repo's `data` symlink points here: ln -s "$HAL_DATA_DIR" data
HAL_DATA_DIR=

# Path to the hal-decrypt executable (see README "HPC bootstrap").
HAL_DECRYPT_BIN=vendor/.hal-venv/bin/hal-decrypt
