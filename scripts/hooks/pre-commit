#!/usr/bin/env python3
"""Pre-commit size guard — CLAUDE.md operating rule 3.

Rejects any commit that (a) stages a path matching **/rollouts/*.jsonl —
raw rollout text (prompts/completions/trajectories) never enters git — or
(b) stages additions totalling more than 20 MB.

Install once per clone (local AND JUPITER):

    git config core.hooksPath scripts/hooks

Stdlib only, so it runs under any python3 (login nodes included).
"""

from __future__ import annotations

import re
import subprocess
import sys
from pathlib import Path

MAX_TOTAL_BYTES = 20 * 2**20  # 20 MB
ROLLOUT_RE = re.compile(r"(^|/)rollouts/[^/]+\.jsonl$")


def violations(entries: list[tuple[str, int]]) -> list[str]:
    """entries: (repo-relative posix path, staged size in bytes). Pure — unit tested."""
    problems = [
        f"{path}: raw rollout JSONL is unpushable (results contract)"
        for path, _ in entries
        if ROLLOUT_RE.search(path)
    ]
    total = sum(size for _, size in entries)
    if total > MAX_TOTAL_BYTES:
        problems.append(
            f"staged additions total {total / 2**20:.1f} MB > 20 MB — "
            "aggregates only; raw data stays on $SCRATCH"
        )
    return problems


def staged_entries() -> list[tuple[str, int]]:
    root = Path(
        subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True,
        ).stdout.strip()
    )
    out = subprocess.run(
        ["git", "diff", "--cached", "--name-only", "-z", "--diff-filter=ACMR"],
        capture_output=True, text=True, check=True, cwd=root,
    ).stdout
    entries = []
    for name in filter(None, out.split("\0")):
        p = root / name
        entries.append((name, p.stat().st_size if p.is_file() else 0))
    return entries


def main() -> int:
    problems = violations(staged_entries())
    if problems:
        print("SIZE GUARD — commit rejected:", file=sys.stderr)
        for p in problems:
            print(f"  - {p}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
